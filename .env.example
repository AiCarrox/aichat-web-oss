# ===== AES-256-GCM 加密(cookie + ShareLink 持久化) =====
# 64 hex 字符: openssl rand -hex 32
ENCRYPTION_KEY=

# ===== PostgreSQL =====
# 本地开发: postgresql://aichat:aichat@localhost:5432/aichat?schema=public
# 生产 docker-compose: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public
DATABASE_URL=

# ===== docker-compose 顶层环境 =====
POSTGRES_USER=aichat
POSTGRES_PASSWORD=aichat
POSTGRES_DB=aichat
APP_PORT=3081

# ===== 默认模型(用户可在 /settings 覆盖) =====
DEFAULT_CHAT_MODEL=gpt-4o
DEFAULT_IMAGE_MODEL=gpt-image-1

# ===== 后台清理过期分享链接的间隔(秒) =====
SHARE_SWEEP_INTERVAL_SEC=60

# ===== 日志 =====
LOG_LEVEL=info
LOG_DIR=/app/logs
